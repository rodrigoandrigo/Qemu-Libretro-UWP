<Page
    x:Class="Qemu_Libretro_UWP.DirectXPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Qemu_Libretro_UWP"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Black">

  <Page.Resources>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#F01F1F1F" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#E6000000" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#CC141414" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#FF9CA3AF" />
    <SolidColorBrush x:Key="SectionLineBrush" Color="#FF5F6368" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FF00C853" />
    <SolidColorBrush x:Key="AutoCommandBrush" Color="#FF7DD3FC" />
    <SolidColorBrush x:Key="AdditionalCommandBrush" Color="#FFFACC15" />
  </Page.Resources>

  <Grid Background="Black">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <CommandBar
        x:Name="bottomAppBar"
        Grid.Row="0"
        Height="56"
        Background="{StaticResource HeaderBackgroundBrush}"
        Foreground="White"
        HorizontalContentAlignment="Right">
      <CommandBar.Content>
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <FontIcon Glyph="&#xE768;" Foreground="{StaticResource AccentBrush}" FontSize="22" />
          <StackPanel MaxWidth="720">
            <TextBlock Text="QEMU Libretro UWP" Foreground="White" FontWeight="SemiBold" />
            <TextBlock
                x:Name="statusText"
                Text="Select boot media, review qemu_cmd_line, then start."
                Foreground="{StaticResource MutedTextBrush}"
                FontSize="12"
                TextTrimming="CharacterEllipsis"
                MaxWidth="720" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" IsHitTestVisible="False">
            <FontIcon x:Name="keyboardCaptureIcon" Glyph="&#xE765;" Foreground="{StaticResource AccentBrush}" FontSize="18" />
            <FontIcon x:Name="mouseCaptureIcon" Glyph="&#xE962;" Foreground="{StaticResource AccentBrush}" FontSize="18" />
          </StackPanel>
        </StackPanel>
      </CommandBar.Content>
      <CommandBar.PrimaryCommands>
        <AppBarButton x:Name="showTabsButton" Icon="Setting" Label="Hide tabs" Click="ShowTabsButton_Click" Foreground="White" />
        <AppBarButton x:Name="startButton" Icon="Play" Label="Start" Click="StartButton_Click" Foreground="White" />
        <AppBarButton x:Name="pauseButton" Icon="Pause" Label="Pause" Click="PauseButton_Click" Foreground="White" IsEnabled="False" />
        <AppBarButton x:Name="resumeButton" Icon="Play" Label="Resume" Click="ResumeButton_Click" Foreground="White" IsEnabled="False" />
        <AppBarButton x:Name="stopButton" Icon="Stop" Label="Stop" Click="StopButton_Click" Foreground="White" IsEnabled="False" />
        <AppBarButton x:Name="shutdownButton" Icon="Cancel" Label="Shutdown" Click="ShutdownButton_Click" Foreground="White" IsEnabled="False" />
      </CommandBar.PrimaryCommands>
    </CommandBar>

    <Grid Grid.Row="1" Background="Black">
      <SwapChainPanel x:Name="swapChainPanel" />

      <Grid x:Name="readyOverlay" IsHitTestVisible="False" Visibility="Collapsed">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
          <TextBlock Text="QEMU Ready" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
          <TextBlock Text="Open Boot, choose media, then press Start." Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
          <FontIcon Glyph="&#xE768;" Foreground="White" FontSize="56" HorizontalAlignment="Center" Opacity="0.95" />
        </StackPanel>
      </Grid>

      <ScrollViewer
          x:Name="topPanel"
          Background="{StaticResource PanelBackgroundBrush}"
          VerticalScrollBarVisibility="Auto"
          HorizontalScrollBarVisibility="Disabled"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
<Pivot x:Name="tabPanel" Grid.Row="0" Foreground="White" Background="Transparent">
            <PivotItem AutomationProperties.Name="Boot">
              <PivotItem.Header>
                <SymbolIcon Symbol="Play" />
              </PivotItem.Header>
              <StackPanel Padding="16,14,16,20" Spacing="14">
                <StackPanel Spacing="3">
                  <TextBlock Text="Boot" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                  <TextBlock Text="Choose media and the generated QEMU command before starting." Foreground="{StaticResource MutedTextBrush}" TextWrapping="WrapWholeWords" />
                </StackPanel>

                <TextBlock Text="MEDIA" Foreground="White" FontWeight="SemiBold" />
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource SectionLineBrush}" BorderThickness="1" Padding="12">
                  <StackPanel Spacing="12">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="Drive media" Foreground="White" FontWeight="SemiBold" />
                        <TextBlock Text="RAW, QCOW, VDI, VMDK, VHD/VHDX, DMG, QED or qemu_cmd_line" Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextWrapping="WrapWholeWords" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Spacing="6" Margin="12,0" VerticalAlignment="Center">
                        <TextBlock x:Name="selectedDriveText" Text="No drive selected" Foreground="{StaticResource MutedTextBrush}" TextWrapping="WrapWholeWords" />
                        <ComboBox x:Name="driveBootMediaBox" Header="Prepared drive media" HorizontalAlignment="Stretch" SelectionChanged="DriveBootMediaBox_SelectionChanged" />
                      </StackPanel>
                      <AppBarButton Grid.Column="2" Icon="OpenFile" Label="Select drive" Click="SelectDriveButton_Click" Foreground="White" />
                      <AppBarButton Grid.Column="3" Icon="Cancel" Label="Remove" Click="RemoveDriveButton_Click" Foreground="White" />
                    </Grid>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="CD-ROM media" Foreground="White" FontWeight="SemiBold" />
                        <TextBlock Text="ISO mounted as media=cdrom via NBD" Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextWrapping="WrapWholeWords" />
                      </StackPanel>
                      <StackPanel Grid.Column="1" Spacing="6" Margin="12,0" VerticalAlignment="Center">
                        <TextBlock x:Name="selectedCdromText" Text="No CD-ROM selected" Foreground="{StaticResource MutedTextBrush}" TextWrapping="WrapWholeWords" />
                        <ComboBox x:Name="cdromBootMediaBox" Header="Prepared CD-ROM media" HorizontalAlignment="Stretch" SelectionChanged="CdromBootMediaBox_SelectionChanged" />
                      </StackPanel>
                      <AppBarButton Grid.Column="2" Icon="OpenFile" Label="Select CD-ROM" Click="SelectCdromButton_Click" Foreground="White" />
                      <AppBarButton Grid.Column="3" Icon="Cancel" Label="Remove" Click="RemoveCdromButton_Click" Foreground="White" />
                    </Grid>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="Boot device" Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" />
                      <ComboBox x:Name="bootDeviceBox" Grid.Column="1" Header="Startup device" SelectedIndex="0" HorizontalAlignment="Left" Width="240" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Auto" />
                        <ComboBoxItem Content="Drive" />
                        <ComboBoxItem Content="CD-ROM" />
                      </ComboBox>
                      <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock x:Name="bootMediaSizeText" Text="boot_media: calculating..." Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                        <Button x:Name="clearBootMediaButton" Content="Clear boot_media" Click="ClearBootMediaButton_Click" />
                      </StackPanel>
                    </Grid>

                    <TextBlock Text="DRIVE OPTIONS" Foreground="White" FontWeight="SemiBold" />
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <ComboBox x:Name="driveFormatBox" Grid.Column="0" Header="Format" SelectedIndex="0" Margin="0,0,8,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Auto" />
                        <ComboBoxItem Content="raw" Tag="raw" />
                        <ComboBoxItem Content="qcow2" Tag="qcow2" />
                        <ComboBoxItem Content="qcow" Tag="qcow" />
                        <ComboBoxItem Content="qed" Tag="qed" />
                        <ComboBoxItem Content="vdi" Tag="vdi" />
                        <ComboBoxItem Content="vmdk" Tag="vmdk" />
                        <ComboBoxItem Content="vpc / VHD" Tag="vpc" />
                        <ComboBoxItem Content="vhdx" Tag="vhdx" />
                        <ComboBoxItem Content="dmg" Tag="dmg" />
                        <ComboBoxItem Content="bochs" Tag="bochs" />
                        <ComboBoxItem Content="cloop" Tag="cloop" />
                        <ComboBoxItem Content="parallels / HDS" Tag="parallels" />
                      </ComboBox>
                      <ComboBox x:Name="driveInterfaceBox" Grid.Column="1" Header="Interface" SelectedIndex="0" Margin="4,0,4,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Auto" />
                        <ComboBoxItem Content="IDE" Tag="ide" />
                        <ComboBoxItem Content="SCSI" Tag="scsi" />
                        <ComboBoxItem Content="VirtIO" Tag="virtio" />
                        <ComboBoxItem Content="USB" Tag="usb" />
                      </ComboBox>
                      <ComboBox x:Name="driveCacheBox" Grid.Column="2" Header="Cache" SelectedIndex="0" Margin="4,0,4,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Default" />
                        <ComboBoxItem Content="none" Tag="none" />
                        <ComboBoxItem Content="writeback" Tag="writeback" />
                        <ComboBoxItem Content="writethrough" Tag="writethrough" />
                        <ComboBoxItem Content="directsync" Tag="directsync" />
                        <ComboBoxItem Content="unsafe" Tag="unsafe" />
                      </ComboBox>
                      <ComboBox x:Name="driveAioBox" Grid.Column="3" Header="AIO" SelectedIndex="0" Margin="8,0,0,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Default" />
                        <ComboBoxItem Content="threads" Tag="threads" />
                        <ComboBoxItem Content="native" Tag="native" />
                      </ComboBox>
                    </Grid>

                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <ComboBox x:Name="driveDiscardBox" Grid.Column="0" Header="Discard" SelectedIndex="0" Margin="0,0,8,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Default" />
                        <ComboBoxItem Content="unmap" Tag="unmap" />
                        <ComboBoxItem Content="ignore" Tag="ignore" />
                      </ComboBox>
                      <ComboBox x:Name="driveSnapshotBox" Grid.Column="1" Header="Snapshot" SelectedIndex="0" Margin="4,0,4,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Default" />
                        <ComboBoxItem Content="On" Tag="on" />
                        <ComboBoxItem Content="Off" Tag="off" />
                      </ComboBox>
                      <ComboBox x:Name="driveReadonlyBox" Grid.Column="2" Header="Readonly" SelectedIndex="0" Margin="8,0,0,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Default" />
                        <ComboBoxItem Content="On" Tag="on" />
                        <ComboBoxItem Content="Off" Tag="off" />
                      </ComboBox>
                    </Grid>

                    <TextBlock Text="CD-ROM OPTIONS" Foreground="White" FontWeight="SemiBold" />
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <ComboBox x:Name="cdromFormatBox" Grid.Column="0" Header="Format" SelectedIndex="0" Margin="0,0,8,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Auto / raw" />
                        <ComboBoxItem Content="raw" Tag="raw" />
                        <ComboBoxItem Content="qcow" Tag="qcow" />
                        <ComboBoxItem Content="qcow2" Tag="qcow2" />
                        <ComboBoxItem Content="qed" Tag="qed" />
                        <ComboBoxItem Content="vdi" Tag="vdi" />
                        <ComboBoxItem Content="vmdk" Tag="vmdk" />
                        <ComboBoxItem Content="vpc / VHD" Tag="vpc" />
                        <ComboBoxItem Content="vhdx" Tag="vhdx" />
                        <ComboBoxItem Content="dmg" Tag="dmg" />
                        <ComboBoxItem Content="bochs" Tag="bochs" />
                        <ComboBoxItem Content="cloop" Tag="cloop" />
                        <ComboBoxItem Content="parallels / HDS" Tag="parallels" />
                      </ComboBox>
                      <ComboBox x:Name="cdromInterfaceBox" Grid.Column="1" Header="Interface" SelectedIndex="0" Margin="4,0,4,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Auto" />
                        <ComboBoxItem Content="IDE" Tag="ide" />
                        <ComboBoxItem Content="SCSI" Tag="scsi" />
                        <ComboBoxItem Content="VirtIO" Tag="virtio" />
                        <ComboBoxItem Content="USB" Tag="usb" />
                      </ComboBox>
                      <ComboBox x:Name="cdromCacheBox" Grid.Column="2" Header="Cache" SelectedIndex="0" Margin="4,0,4,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Default" />
                        <ComboBoxItem Content="none" Tag="none" />
                        <ComboBoxItem Content="writeback" Tag="writeback" />
                        <ComboBoxItem Content="writethrough" Tag="writethrough" />
                      </ComboBox>
                      <ComboBox x:Name="cdromAioBox" Grid.Column="3" Header="AIO" SelectedIndex="0" Margin="8,0,0,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Default" />
                        <ComboBoxItem Content="threads" Tag="threads" />
                        <ComboBoxItem Content="native" Tag="native" />
                      </ComboBox>
                    </Grid>
                  </StackPanel>
                </Border>

                <TextBlock Text="MACHINE" Foreground="White" FontWeight="SemiBold" />
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource SectionLineBrush}" BorderThickness="1" Padding="12">
                  <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                      <TextBlock Text="Architecture" Foreground="White" FontWeight="SemiBold" />
                      <StackPanel Orientation="Horizontal" Spacing="18" VerticalAlignment="Center">
                        <ComboBox x:Name="architectureBox" Header="QEMU target" SelectedIndex="0" Width="220" HorizontalAlignment="Left" SelectionChanged="Architecture_Changed">
                          <ComboBoxItem Content="x86_64" />
                          <ComboBoxItem Content="i386" />
                          <ComboBoxItem Content="aarch64" />
                          <ComboBoxItem Content="alpha" />
                          <ComboBoxItem Content="arm" />
                          <ComboBoxItem Content="m68k" />
                          <ComboBoxItem Content="mips" />
                          <ComboBoxItem Content="mips64" />
                          <ComboBoxItem Content="mips64el" />
                          <ComboBoxItem Content="mipsel" />
                          <ComboBoxItem Content="ppc" />
                          <ComboBoxItem Content="ppc64" />
                          <ComboBoxItem Content="riscv32" />
                          <ComboBoxItem Content="riscv64" />
                          <ComboBoxItem Content="s390x" />
                          <ComboBoxItem Content="sparc" />
                          <ComboBoxItem Content="sparc64" />
                        </ComboBox>
                        <StackPanel x:Name="selectorLoadProgressPanel" Width="220" VerticalAlignment="Bottom" Visibility="Collapsed">
                          <TextBlock
                              x:Name="selectorLoadProgressText"
                              Text="0%"
                              Foreground="{StaticResource MutedTextBrush}"
                              FontSize="11"
                              TextAlignment="Right" />
                          <ProgressBar
                              x:Name="selectorLoadProgressBar"
                              Minimum="0"
                              Maximum="100"
                              Value="0"
                              Height="3"
                              Foreground="{StaticResource AccentBrush}"
                              Background="#663F3F46" />
                        </StackPanel>
                      </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="4">
                      <TextBlock Text="Memory" Foreground="White" FontWeight="SemiBold" />
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="memorySlider" Minimum="0" Maximum="8192" Value="512" StepFrequency="16" TickFrequency="1024" Foreground="{StaticResource AccentBrush}" ValueChanged="MemorySlider_ValueChanged" />
                        <TextBlock x:Name="memoryValueText" Grid.Column="1" Text="512 MB" Foreground="White" FontWeight="SemiBold" TextAlignment="Right" VerticalAlignment="Center" />
                      </Grid>
                      <TextBlock Text="0 MB uses the QEMU default. Values above 0 are written as -m XM." Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                      <TextBlock Text="SMP" Foreground="White" FontWeight="SemiBold" />
                      <ComboBox x:Name="smpBox" Header="CPU count" SelectedIndex="0" Width="180" HorizontalAlignment="Left" SelectionChanged="QemuOption_Changed">
                        <ComboBoxItem Content="1 CPU" Tag="1" />
                        <ComboBoxItem Content="2 CPUs" Tag="2" />
                        <ComboBoxItem Content="3 CPUs" Tag="3" />
                        <ComboBoxItem Content="4 CPUs" Tag="4" />
                        <ComboBoxItem Content="5 CPUs" Tag="5" />
                        <ComboBoxItem Content="6 CPUs" Tag="6" />
                        <ComboBoxItem Content="7 CPUs" Tag="7" />
                        <ComboBoxItem Content="8 CPUs" Tag="8" />
                        <ComboBoxItem Content="9 CPUs" Tag="9" />
                        <ComboBoxItem Content="10 CPUs" Tag="10" />
                        <ComboBoxItem Content="11 CPUs" Tag="11" />
                        <ComboBoxItem Content="12 CPUs" Tag="12" />
                        <ComboBoxItem Content="13 CPUs" Tag="13" />
                        <ComboBoxItem Content="14 CPUs" Tag="14" />
                        <ComboBoxItem Content="15 CPUs" Tag="15" />
                        <ComboBoxItem Content="16 CPUs" Tag="16" />
                      </ComboBox>
                      <TextBlock Text="Written as -smp N. The default startup value is 1 CPU." Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                    </StackPanel>

                    <TextBlock Text="BOOT OPTIONS" Foreground="White" FontWeight="SemiBold" />
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <ComboBox x:Name="bootOrderBox" Grid.Column="0" Header="Boot order" SelectedIndex="0" Margin="0,0,8,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Auto" />
                        <ComboBoxItem Content="Drive first" Tag="c" />
                        <ComboBoxItem Content="CD-ROM first" Tag="d" />
                        <ComboBoxItem Content="Network first" Tag="n" />
                        <ComboBoxItem Content="Floppy first" Tag="a" />
                        <ComboBoxItem Content="CD-ROM then Drive" Tag="dc" />
                        <ComboBoxItem Content="Drive then CD-ROM" Tag="cd" />
                      </ComboBox>
                      <ComboBox x:Name="bootMenuBox" Grid.Column="1" Header="Boot menu" SelectedIndex="0" Margin="4,0,4,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Default" />
                        <ComboBoxItem Content="On" Tag="on" />
                        <ComboBoxItem Content="Off" Tag="off" />
                      </ComboBox>
                      <ComboBox x:Name="bootStrictBox" Grid.Column="2" Header="Strict boot" SelectedIndex="0" Margin="4,0,4,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Default" />
                        <ComboBoxItem Content="On" Tag="on" />
                        <ComboBoxItem Content="Off" Tag="off" />
                      </ComboBox>
                      <ComboBox x:Name="bootOnceBox" Grid.Column="3" Header="Boot once" SelectedIndex="0" Margin="8,0,0,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="None" />
                        <ComboBoxItem Content="Drive" Tag="c" />
                        <ComboBoxItem Content="CD-ROM" Tag="d" />
                        <ComboBoxItem Content="Network" Tag="n" />
                        <ComboBoxItem Content="Floppy" Tag="a" />
                      </ComboBox>
                    </Grid>

                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <ComboBox x:Name="machineBox" Grid.Column="0" Header="Machine" Margin="0,0,8,0" SelectionChanged="QemuOption_Changed" />
                      <ComboBox x:Name="cpuBox" Grid.Column="1" Header="CPU" Margin="4,0,4,0" SelectionChanged="QemuOption_Changed" />
                      <ComboBox x:Name="vgaBox" Grid.Column="2" Header="VGA" Margin="8,0,0,0" SelectionChanged="QemuOption_Changed" />
                    </Grid>

                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <ComboBox x:Name="deviceBox" Grid.Column="0" Header="Device" Margin="0,0,8,0" SelectionChanged="QemuOption_Changed" />
                      <ComboBox x:Name="monitorBox" Grid.Column="1" Header="Monitor" Margin="4,0,4,0" SelectionChanged="QemuOption_Changed" />
                      <ComboBox x:Name="netdevBox" Grid.Column="2" Header="Netdev" Margin="8,0,0,0" SelectionChanged="QemuOption_Changed" />
                    </Grid>

                    <TextBlock Text="DEVICE OPTIONS" Foreground="White" FontWeight="SemiBold" />
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <ComboBox x:Name="audioDeviceBox" Grid.Column="0" Header="Audio device" SelectedIndex="0" Margin="0,0,8,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="None" />
                        <ComboBoxItem Content="AC97" Tag="AC97" />
                        <ComboBoxItem Content="Intel HDA" Tag="intel-hda" />
                        <ComboBoxItem Content="ES1370" Tag="ES1370" />
                        <ComboBoxItem Content="SB16" Tag="sb16" />
                        <ComboBoxItem Content="PC speaker" Tag="pcspk" />
                      </ComboBox>
                      <ComboBox x:Name="usbModeBox" Grid.Column="1" Header="USB" SelectedIndex="0" Margin="4,0,4,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Default" />
                        <ComboBoxItem Content="Enable USB" Tag="on" />
                        <ComboBoxItem Content="Disable USB" Tag="off" />
                        <ComboBoxItem Content="EHCI controller" Tag="ehci" />
                        <ComboBoxItem Content="XHCI controller" Tag="xhci" />
                      </ComboBox>
                      <ComboBox x:Name="inputDeviceBox" Grid.Column="2" Header="Input device" SelectedIndex="0" Margin="8,0,0,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Default" />
                        <ComboBoxItem Content="USB tablet" Tag="usb-tablet" />
                        <ComboBoxItem Content="USB mouse" Tag="usb-mouse" />
                        <ComboBoxItem Content="USB keyboard" Tag="usb-kbd" />
                        <ComboBoxItem Content="Tablet + keyboard" Tag="usb-tablet,usb-kbd" />
                      </ComboBox>
                    </Grid>

                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <ComboBox x:Name="rtcBaseBox" Grid.Column="0" Header="RTC base" SelectedIndex="0" Margin="0,0,8,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Default" />
                        <ComboBoxItem Content="UTC" Tag="utc" />
                        <ComboBoxItem Content="Local time" Tag="localtime" />
                      </ComboBox>
                      <ComboBox x:Name="rtcClockBox" Grid.Column="1" Header="RTC clock" SelectedIndex="0" Margin="4,0,4,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Default" />
                        <ComboBoxItem Content="host" Tag="host" />
                        <ComboBoxItem Content="vm" Tag="vm" />
                      </ComboBox>
                      <ComboBox x:Name="debugBehaviorBox" Grid.Column="2" Header="Runtime behavior" SelectedIndex="0" Margin="8,0,0,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Default" />
                        <ComboBoxItem Content="No reboot" Tag="-no-reboot" />
                        <ComboBoxItem Content="No shutdown" Tag="-no-shutdown" />
                        <ComboBoxItem Content="No reboot + no shutdown" Tag="-no-reboot -no-shutdown" />
                      </ComboBox>
                    </Grid>

                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <ComboBox x:Name="serialBox" Grid.Column="0" Header="Serial" SelectedIndex="0" Margin="0,0,8,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Default" />
                        <ComboBoxItem Content="none" Tag="none" />
                        <ComboBoxItem Content="null" Tag="null" />
                        <ComboBoxItem Content="vc" Tag="vc" />
                        <ComboBoxItem Content="mon:stdio" Tag="mon:stdio" />
                      </ComboBox>
                      <ComboBox x:Name="parallelBox" Grid.Column="1" Header="Parallel" SelectedIndex="0" Margin="4,0,4,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Default" />
                        <ComboBoxItem Content="none" Tag="none" />
                        <ComboBoxItem Content="null" Tag="null" />
                      </ComboBox>
                      <ComboBox x:Name="debugFlagsBox" Grid.Column="2" Header="Debug flags" SelectedIndex="0" Margin="8,0,0,0" SelectionChanged="BootOption_Changed">
                        <ComboBoxItem Content="Default" />
                        <ComboBoxItem Content="guest_errors" Tag="guest_errors" />
                        <ComboBoxItem Content="unimp" Tag="unimp" />
                        <ComboBoxItem Content="cpu_reset" Tag="cpu_reset" />
                        <ComboBoxItem Content="guest_errors + unimp" Tag="guest_errors,unimp" />
                      </ComboBox>
                    </Grid>

                    <TextBlock Text="FIRMWARE AND DIRECT KERNEL BOOT" Foreground="White" FontWeight="SemiBold" />
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Margin="0,0,8,0" Spacing="6">
                        <ComboBox x:Name="biosPathSelectorBox" Header="BIOS / firmware selector" HorizontalAlignment="Stretch" SelectedIndex="0" SelectionChanged="FirmwarePathSelector_SelectionChanged" />
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <TextBox x:Name="biosPathBox" Header="BIOS / firmware path" PlaceholderText="bios.bin or firmware.fd" TextWrapping="NoWrap" TextChanged="BootOptionText_Changed" />
                          <AppBarButton x:Name="clearBiosPathButton" Grid.Column="1" Icon="Cancel" Label="Clear" Click="ClearFirmwarePathButton_Click" Foreground="White" Margin="6,24,0,0" />
                        </Grid>
                      </StackPanel>
                      <StackPanel Grid.Column="1" Margin="8,0,0,0" Spacing="6">
                        <ComboBox x:Name="kernelPathSelectorBox" Header="Kernel selector" HorizontalAlignment="Stretch" SelectedIndex="0" SelectionChanged="FirmwarePathSelector_SelectionChanged" />
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <TextBox x:Name="kernelPathBox" Header="Kernel path" PlaceholderText="vmlinuz or kernel image" TextWrapping="NoWrap" TextChanged="BootOptionText_Changed" />
                          <AppBarButton x:Name="clearKernelPathButton" Grid.Column="1" Icon="Cancel" Label="Clear" Click="ClearFirmwarePathButton_Click" Foreground="White" Margin="6,24,0,0" />
                        </Grid>
                      </StackPanel>
                    </Grid>

                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Margin="0,0,8,0" Spacing="6">
                        <ComboBox x:Name="initrdPathSelectorBox" Header="Initrd selector" HorizontalAlignment="Stretch" SelectedIndex="0" SelectionChanged="FirmwarePathSelector_SelectionChanged" />
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <TextBox x:Name="initrdPathBox" Header="Initrd path" PlaceholderText="initrd.img" TextWrapping="NoWrap" TextChanged="BootOptionText_Changed" />
                          <AppBarButton x:Name="clearInitrdPathButton" Grid.Column="1" Icon="Cancel" Label="Clear" Click="ClearFirmwarePathButton_Click" Foreground="White" Margin="6,24,0,0" />
                        </Grid>
                      </StackPanel>
                      <StackPanel Grid.Column="1" Margin="4,0,4,0" Spacing="6">
                        <ComboBox x:Name="dtbPathSelectorBox" Header="DTB selector" HorizontalAlignment="Stretch" SelectedIndex="0" SelectionChanged="FirmwarePathSelector_SelectionChanged" />
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <TextBox x:Name="dtbPathBox" Header="DTB path" PlaceholderText="board.dtb" TextWrapping="NoWrap" TextChanged="BootOptionText_Changed" />
                          <AppBarButton x:Name="clearDtbPathButton" Grid.Column="1" Icon="Cancel" Label="Clear" Click="ClearFirmwarePathButton_Click" Foreground="White" Margin="6,24,0,0" />
                        </Grid>
                      </StackPanel>
                      <Grid Grid.Column="2" Margin="8,0,0,0">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="kernelAppendBox" Header="Kernel append" PlaceholderText="root=/dev/vda1 console=ttyS0" TextWrapping="NoWrap" TextChanged="BootOptionText_Changed" />
                        <AppBarButton x:Name="clearKernelAppendButton" Grid.Column="1" Icon="Cancel" Label="Clear" Click="ClearFirmwarePathButton_Click" Foreground="White" Margin="6,24,0,0" />
                      </Grid>
                    </Grid>

                    <StackPanel Spacing="4">
                      <Grid>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            x:Name="argumentsHelpButton"
                            Grid.Row="0"
                            Text="?"
                            Foreground="{StaticResource AccentBrush}"
                            FontSize="20"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Left"
                            PointerEntered="ArgumentsHelpButton_PointerEntered"
                            PointerExited="ArgumentsHelpButton_PointerExited" />
                        <Border
                            x:Name="argumentsHelpPanel"
                            Grid.Row="1"
                            Visibility="Collapsed"
                            Background="#EE1F1F1F"
                            BorderBrush="{StaticResource SectionLineBrush}"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,2,0,6"
                            PointerEntered="ArgumentsHelpButton_PointerEntered"
                            PointerExited="ArgumentsHelpButton_PointerExited">
                          <TextBlock Foreground="White" TextWrapping="WrapWholeWords">
                            <Run Text="Common supported arguments: " />
                            <Run Text="-machine, -M, -cpu, -smp, -vga, -device, -drive, -cdrom, -boot, -netdev, -nic, -usb, -rtc, -serial, -parallel, -monitor, -no-acpi, -no-reboot. " />
                            <Run Text="The app already generates -libretro, memory, Drive/CD-ROM media, and boot order." />
                          </TextBlock>
                        </Border>
                        <Grid Grid.Row="2">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <TextBox x:Name="extraArgumentsBox" Header="Additional QEMU arguments" PlaceholderText="-no-reboot -rtc base=localtime" TextWrapping="NoWrap" TextChanged="AdditionalArguments_Changed" />
                          <Button Grid.Column="1" Content="Update qemu_cmd_line" Margin="10,24,0,0" Click="UpdateCommandLineButton_Click" />
                        </Grid>
                      </Grid>
                    </StackPanel>

                    <StackPanel Spacing="4">
                      <TextBlock Text="Profile" Foreground="White" FontWeight="SemiBold" />
                      <ComboBox x:Name="diagnosticProfileBox" Header="QEMU profile" SelectedIndex="0" Width="360" HorizontalAlignment="Left" SelectionChanged="DiagnosticProfile_Changed">
                        <ComboBoxItem Content="Normal command" />
                        <ComboBoxItem Content="Video Teste" />
                        <ComboBoxItem Content="Linux cloud qcow2" />
                        <ComboBoxItem Content="Ubuntu 10" />
                        <ComboBoxItem Content="Ubuntu 14" />
                        <ComboBoxItem Content="Windows 98" />
                        <ComboBoxItem Content="Windows XP" />
                        <ComboBoxItem Content="Windows 7" />
                      </ComboBox>
                      <TextBlock Text="Video Teste starts without media. Other profiles tune the selected QEMU target and machine options." Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                  </StackPanel>
                </Border>
              </StackPanel>
            </PivotItem>

            <PivotItem AutomationProperties.Name="Errors">
              <PivotItem.Header>
                <SymbolIcon Symbol="Comment" />
              </PivotItem.Header>
              <StackPanel Padding="16,14,16,24" Spacing="14">
                <StackPanel Spacing="4">
                  <TextBlock Text="Errors" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                  <TextBlock Text="Runtime and configuration problems are collected here." Foreground="{StaticResource MutedTextBrush}" TextWrapping="WrapWholeWords" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <Button x:Name="clearErrorLogButton" Content="Clear errors and logs" Click="ClearErrorLogButton_Click" />
                </StackPanel>
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource SectionLineBrush}" BorderThickness="1" Padding="12">
                  <TextBox x:Name="errorLogBox" Text="No errors recorded." IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" MinHeight="260" HorizontalAlignment="Stretch" />
                </Border>
              </StackPanel>
            </PivotItem>

            <PivotItem AutomationProperties.Name="qemu commands">
              <PivotItem.Header>
                <SymbolIcon Symbol="Page" />
              </PivotItem.Header>
              <StackPanel Padding="16,14,16,24" Spacing="14">
                <StackPanel Spacing="4">
                  <TextBlock Text="qemu commands" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                  <TextBlock Text="Review or edit the command passed to qemu-libretro." Foreground="{StaticResource MutedTextBrush}" TextWrapping="WrapWholeWords" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <Button x:Name="resetCommandDefaultsButton" Content="Reset defaults" Click="ResetCommandDefaultsButton_Click" />
                  <Button x:Name="alignCommandLineButton" Content="Align vertical" Click="AlignCommandLineButton_Click" />
                </StackPanel>
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource SectionLineBrush}" BorderThickness="1" Padding="12">
                  <RichTextBlock x:Name="commandPreviewBlock" FontFamily="Consolas" FontSize="13" TextWrapping="Wrap" />
                </Border>
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource SectionLineBrush}" BorderThickness="1" Padding="12">
                  <TextBox x:Name="commandLineBox" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" MinHeight="260" Header="Generated command" PlaceholderText="The generated qemu_cmd_line will appear here." />
                </Border>
              </StackPanel>
            </PivotItem>
          </Pivot>
        </Grid>
      </ScrollViewer>
    </Grid>
  </Grid>
</Page>





