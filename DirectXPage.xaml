<Page
    x:Class="Qemu_Libretro_UWP.DirectXPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Qemu_Libretro_UWP"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Black">

  <Page.Resources>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#F01F1F1F" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#E6000000" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#CC141414" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#FF9CA3AF" />
    <SolidColorBrush x:Key="SectionLineBrush" Color="#FF5F6368" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FF00C853" />
  </Page.Resources>

  <Grid Background="Black">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <CommandBar
        x:Name="bottomAppBar"
        Grid.Row="0"
        Height="56"
        Background="{StaticResource HeaderBackgroundBrush}"
        Foreground="White"
        HorizontalContentAlignment="Right">
      <CommandBar.Content>
        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <FontIcon Glyph="&#xE768;" Foreground="{StaticResource AccentBrush}" FontSize="22" />
          <StackPanel>
            <TextBlock Text="QEMU Libretro UWP" Foreground="White" FontWeight="SemiBold" />
            <TextBlock
                x:Name="statusText"
                Text="Select boot media, review qemu_cmd_line, then start."
                Foreground="{StaticResource MutedTextBrush}"
                FontSize="12"
                TextTrimming="CharacterEllipsis"
                MaxWidth="720" />
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" IsHitTestVisible="False">
            <FontIcon x:Name="keyboardCaptureIcon" Glyph="&#xE765;" Foreground="{StaticResource AccentBrush}" FontSize="18" />
            <FontIcon x:Name="mouseCaptureIcon" Glyph="&#xE962;" Foreground="{StaticResource AccentBrush}" FontSize="18" />
          </StackPanel>
        </StackPanel>
      </CommandBar.Content>
      <CommandBar.PrimaryCommands>
        <AppBarButton x:Name="showTabsButton" Icon="Setting" Label="Hide tabs" Click="ShowTabsButton_Click" Foreground="White" />
        <AppBarButton x:Name="startButton" Icon="Play" Label="Start" Click="StartButton_Click" Foreground="White" />
      </CommandBar.PrimaryCommands>
    </CommandBar>

    <Grid Grid.Row="1" Background="Black">
      <SwapChainPanel x:Name="swapChainPanel" />

      <Grid x:Name="readyOverlay" IsHitTestVisible="False" Visibility="Collapsed">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
          <TextBlock Text="QEMU Ready" Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
          <TextBlock Text="Open Boot, choose media, then press Start." Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Center" />
          <FontIcon Glyph="&#xE768;" Foreground="White" FontSize="56" HorizontalAlignment="Center" Opacity="0.95" />
        </StackPanel>
      </Grid>

      <ScrollViewer
          x:Name="topPanel"
          Background="{StaticResource PanelBackgroundBrush}"
          VerticalScrollBarVisibility="Auto"
          HorizontalScrollBarVisibility="Disabled"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
<Pivot x:Name="tabPanel" Grid.Row="0" Foreground="White" Background="Transparent">
            <PivotItem AutomationProperties.Name="Boot">
              <PivotItem.Header>
                <SymbolIcon Symbol="Play" />
              </PivotItem.Header>
              <StackPanel Padding="16,14,16,20" Spacing="14">
                <StackPanel Spacing="3">
                  <TextBlock Text="Boot" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                  <TextBlock Text="Choose media and the generated QEMU command before starting." Foreground="{StaticResource MutedTextBrush}" TextWrapping="WrapWholeWords" />
                </StackPanel>

                <TextBlock Text="MEDIA" Foreground="White" FontWeight="SemiBold" />
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource SectionLineBrush}" BorderThickness="1" Padding="12">
                  <StackPanel Spacing="12">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="Drive media" Foreground="White" FontWeight="SemiBold" />
                        <TextBlock Text="RAW, QCOW, VDI, VMDK, VHD/VHDX, DMG, QED or qemu_cmd_line" Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextWrapping="WrapWholeWords" />
                      </StackPanel>
                      <TextBlock x:Name="selectedDriveText" Grid.Column="1" Text="No drive selected" Foreground="{StaticResource MutedTextBrush}" TextWrapping="WrapWholeWords" Margin="12,0" VerticalAlignment="Center" />
                      <AppBarButton Grid.Column="2" Icon="OpenFile" Label="Select drive" Click="SelectDriveButton_Click" Foreground="White" />
                    </Grid>
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="CD-ROM media" Foreground="White" FontWeight="SemiBold" />
                        <TextBlock Text="ISO mounted with -cdrom via NBD" Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextWrapping="WrapWholeWords" />
                      </StackPanel>
                      <TextBlock x:Name="selectedCdromText" Grid.Column="1" Text="No CD-ROM selected" Foreground="{StaticResource MutedTextBrush}" TextWrapping="WrapWholeWords" Margin="12,0" VerticalAlignment="Center" />
                      <AppBarButton Grid.Column="2" Icon="OpenFile" Label="Select CD-ROM" Click="SelectCdromButton_Click" Foreground="White" />
                    </Grid>
                  </StackPanel>
                </Border>

                <TextBlock Text="MACHINE" Foreground="White" FontWeight="SemiBold" />
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource SectionLineBrush}" BorderThickness="1" Padding="12">
                  <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                      <TextBlock Text="Architecture" Foreground="White" FontWeight="SemiBold" />
                      <ComboBox x:Name="architectureBox" Header="QEMU target" SelectedIndex="0" Width="220" HorizontalAlignment="Left" SelectionChanged="Architecture_Changed">
                        <ComboBoxItem Content="x86_64" />
                        <ComboBoxItem Content="i386" />
                        <ComboBoxItem Content="aarch64" />
                        <ComboBoxItem Content="alpha" />
                        <ComboBoxItem Content="arm" />
                        <ComboBoxItem Content="m68k" />
                        <ComboBoxItem Content="mips" />
                        <ComboBoxItem Content="mips64" />
                        <ComboBoxItem Content="mips64el" />
                        <ComboBoxItem Content="mipsel" />
                        <ComboBoxItem Content="ppc" />
                        <ComboBoxItem Content="ppc64" />
                        <ComboBoxItem Content="riscv32" />
                        <ComboBoxItem Content="riscv64" />
                        <ComboBoxItem Content="s390x" />
                        <ComboBoxItem Content="sparc" />
                        <ComboBoxItem Content="sparc64" />
                      </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="4">
                      <TextBlock Text="Memory" Foreground="White" FontWeight="SemiBold" />
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <Slider x:Name="memorySlider" Minimum="0" Maximum="8192" Value="512" StepFrequency="16" TickFrequency="1024" Foreground="{StaticResource AccentBrush}" ValueChanged="MemorySlider_ValueChanged" />
                        <TextBlock x:Name="memoryValueText" Grid.Column="1" Text="512 MB" Foreground="White" FontWeight="SemiBold" TextAlignment="Right" VerticalAlignment="Center" />
                      </Grid>
                      <TextBlock Text="0 MB uses the QEMU default. Values above 0 are written as -m XM." Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                      <Grid>
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            x:Name="argumentsHelpButton"
                            Grid.Row="0"
                            Text="?"
                            Foreground="{StaticResource AccentBrush}"
                            FontSize="20"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Left"
                            PointerEntered="ArgumentsHelpButton_PointerEntered"
                            PointerExited="ArgumentsHelpButton_PointerExited" />
                        <Border
                            x:Name="argumentsHelpPanel"
                            Grid.Row="1"
                            Visibility="Collapsed"
                            Background="#EE1F1F1F"
                            BorderBrush="{StaticResource SectionLineBrush}"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,2,0,6"
                            PointerEntered="ArgumentsHelpButton_PointerEntered"
                            PointerExited="ArgumentsHelpButton_PointerExited">
                          <TextBlock Foreground="White" TextWrapping="WrapWholeWords">
                            <Run Text="Common supported arguments: " />
                            <Run Text="-machine, -M, -cpu, -smp, -vga, -device, -drive, -cdrom, -boot, -netdev, -nic, -usb, -rtc, -serial, -parallel, -monitor, -no-acpi, -no-reboot. " />
                            <Run Text="The app already generates -libretro, memory, Drive/CD-ROM media, and boot order." />
                          </TextBlock>
                        </Border>
                        <Grid Grid.Row="2">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <TextBox x:Name="extraArgumentsBox" Header="Additional QEMU arguments" PlaceholderText="-cpu qemu64 -vga std -no-reboot" TextWrapping="NoWrap" />
                          <Button Grid.Column="1" Content="Update qemu_cmd_line" Margin="10,24,0,0" Click="UpdateCommandLineButton_Click" />
                        </Grid>
                      </Grid>
                    </StackPanel>

                    <StackPanel Spacing="4">
                      <TextBlock Text="Test profile" Foreground="White" FontWeight="SemiBold" />
                      <ComboBox x:Name="diagnosticProfileBox" Header="QEMU startup test" SelectedIndex="0" Width="360" HorizontalAlignment="Left" SelectionChanged="DiagnosticProfile_Changed">
                        <ComboBoxItem Content="Normal command" />
                        <ComboBoxItem Content="Empty CD-ROM no file" />
                        <ComboBoxItem Content="Null block" />
                      </ComboBox>
                      <TextBlock Text="Use Normal command for boot. Other profiles are diagnostics only." Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextWrapping="WrapWholeWords" />
                    </StackPanel>
                  </StackPanel>
                </Border>
              </StackPanel>
            </PivotItem>

            <PivotItem AutomationProperties.Name="Errors">
              <PivotItem.Header>
                <SymbolIcon Symbol="Comment" />
              </PivotItem.Header>
              <StackPanel Padding="16,14,16,24" Spacing="14">
                <StackPanel Spacing="4">
                  <TextBlock Text="Errors" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                  <TextBlock Text="Runtime and configuration problems are collected here." Foreground="{StaticResource MutedTextBrush}" TextWrapping="WrapWholeWords" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <Button x:Name="detectTargetsButton" Content="Detect supported systems" Click="DetectTargetsButton_Click" IsEnabled="False" />
                </StackPanel>
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource SectionLineBrush}" BorderThickness="1" Padding="12">
                  <TextBox x:Name="errorLogBox" Text="No errors recorded." IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" MinHeight="260" HorizontalAlignment="Stretch" />
                </Border>
              </StackPanel>
            </PivotItem>

            <PivotItem AutomationProperties.Name="qemu_cmd_line">
              <PivotItem.Header>
                <SymbolIcon Symbol="Page" />
              </PivotItem.Header>
              <StackPanel Padding="16,14,16,24" Spacing="14">
                <StackPanel Spacing="4">
                  <TextBlock Text="qemu_cmd_line" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                  <TextBlock Text="Review or edit the command passed to qemu-libretro." Foreground="{StaticResource MutedTextBrush}" TextWrapping="WrapWholeWords" />
                </StackPanel>
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource SectionLineBrush}" BorderThickness="1" Padding="12">
                  <TextBox x:Name="commandLineBox" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" MinHeight="260" Header="Generated command" PlaceholderText="The generated qemu_cmd_line will appear here." />
                </Border>
              </StackPanel>
            </PivotItem>
          </Pivot>
        </Grid>
      </ScrollViewer>
    </Grid>
  </Grid>
</Page>





